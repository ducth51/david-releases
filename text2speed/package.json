    "express": "^4.19.2",
    "onnxruntime-web": "^1.20.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "onnxruntime-node": "^1.27.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7",
    "wrangler": "^4.114.0"
