{
  "name": "nghi-tts-clone",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"node scripts/dev-server.js\" \"vite\"",
    "dev:web": "vite",
    "dev:server": "node scripts/dev-server.js",
    "build": "node scripts/build-manifest.js && vite build && node scripts/prune-build.js",
    "preview": "vite preview",
